{
  "info": {
    "_postman_id": "social-feed-api-v1",
    "name": "Social Feed API",
    "description": "Production-ready social media backend — authentication, users, posts, comments, likes, stories, messages, groups, and notifications.\n\n**Setup:**\n1. Run the *Register* or *Login* request — tokens are saved automatically to `{{accessToken}}` and `{{refreshToken}}`.\n2. All authenticated endpoints use `{{accessToken}}` from the collection variable.\n3. Set `{{baseUrl}}` to `http://localhost:3000` (already set as the default).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",         "value": "http://localhost:3000", "type": "string" },
    { "key": "accessToken",     "value": "", "type": "string" },
    { "key": "refreshToken",    "value": "", "type": "string" },
    { "key": "userId",          "value": "", "type": "string" },
    { "key": "postId",          "value": "", "type": "string" },
    { "key": "commentId",       "value": "", "type": "string" },
    { "key": "storyId",         "value": "", "type": "string" },
    { "key": "groupId",         "value": "", "type": "string" },
    { "key": "groupPostId",     "value": "", "type": "string" },
    { "key": "groupCommentId",  "value": "", "type": "string" },
    { "key": "messageId",       "value": "", "type": "string" },
    { "key": "notificationId",  "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "System",
      "description": "Health and status monitoring endpoints",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/health", "host": ["{{baseUrl}}"], "path": ["health"] },
            "description": "Returns service health. No auth required."
          }
        },
        {
          "name": "API Status",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/status", "host": ["{{baseUrl}}"], "path": ["status"] },
            "description": "Returns API running status."
          }
        },
        {
          "name": "Endpoint Catalogue",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/endpoints", "host": ["{{baseUrl}}"], "path": ["api", "endpoints"] },
            "description": "Returns every available API endpoint as JSON."
          }
        }
      ]
    },
    {
      "name": "Auth",
      "description": "User authentication — register, login, token refresh, profile, password reset",
      "item": [
        {
          "name": "Register",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) {", "  const json = pm.response.json();", "  pm.collectionVariables.set('accessToken',  json.data.tokens.accessToken);", "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);", "  pm.collectionVariables.set('userId',       json.data.user.id);", "}"], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"SecurePass123!\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/register", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","register"] },
            "description": "Register a new user. Saves accessToken, refreshToken, userId."
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) {", "  const json = pm.response.json();", "  pm.collectionVariables.set('accessToken',  json.data.tokens.accessToken);", "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);", "  pm.collectionVariables.set('userId',       json.data.user.id);", "}"], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john.doe@example.com\",\n  \"password\": \"SecurePass123!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/login", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","login"] },
            "description": "Login and receive JWT token pair."
          }
        },
        {
          "name": "Refresh Token",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 200) {", "  const json = pm.response.json();", "  pm.collectionVariables.set('accessToken',  json.data.tokens.accessToken);", "  pm.collectionVariables.set('refreshToken', json.data.tokens.refreshToken);", "}"], "type": "text/javascript" } }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/refresh-token", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","refresh-token"] },
            "description": "Exchange refresh token for new token pair."
          }
        },
        {
          "name": "Get Profile",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/profile", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","profile"] },
            "description": "Get authenticated user profile."
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/auth/logout", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","logout"] },
            "description": "Logout (stateless JWT)."
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"john.doe@example.com\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/forgot-password", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","forgot-password"] },
            "description": "Request a password-reset email."
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"<reset-token-from-email>\",\n  \"newPassword\": \"NewSecurePass123!\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/auth/reset-password", "host": ["{{baseUrl}}"], "path": ["api","v1","auth","reset-password"] },
            "description": "Reset password using emailed token."
          }
        }
      ]
    },
    {
      "name": "Users",
      "description": "User profiles, follow system, and search",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"] },
            "description": "Get authenticated user profile with follow stats."
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PATCH", "header": [],
            "body": { "mode": "formdata", "formdata": [
              { "key": "firstName", "value": "Jane", "type": "text" },
              { "key": "lastName",  "value": "Doe",  "type": "text" },
              { "key": "bio",       "value": "Software engineer & coffee lover", "type": "text" },
              { "key": "avatar",    "type": "file",  "src": "" }
            ]},
            "url": { "raw": "{{baseUrl}}/api/v1/users/me", "host": ["{{baseUrl}}"], "path": ["api","v1","users","me"] },
            "description": "Update profile. avatar is an optional file upload (multipart/form-data)."
          }
        },
        {
          "name": "Search Users",
          "request": {
            "auth": { "type": "noauth" }, "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/users/search?q=john&limit=10", "host": ["{{baseUrl}}"], "path": ["api","v1","users","search"], "query": [{"key":"q","value":"john"},{"key":"limit","value":"10"}] },
            "description": "Search users by name or email."
          }
        },
        {
          "name": "Get User By ID",
          "request": {
            "auth": { "type": "noauth" }, "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/users/{{userId}}", "host": ["{{baseUrl}}"], "path": ["api","v1","users","{{userId}}"] },
            "description": "Get a public user profile."
          }
        },
        {
          "name": "Follow / Unfollow User",
          "request": {
            "method": "POST", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/users/{{userId}}/follow", "host": ["{{baseUrl}}"], "path": ["api","v1","users","{{userId}}","follow"] },
            "description": "Toggle follow. Returns followed:true when followed, false when unfollowed."
          }
        },
        {
          "name": "Get User Followers",
          "request": {
            "auth": { "type": "noauth" }, "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/users/{{userId}}/followers?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api","v1","users","{{userId}}","followers"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] },
            "description": "Get users who follow the given user."
          }
        },
        {
          "name": "Get User Following",
          "request": {
            "auth": { "type": "noauth" }, "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/users/{{userId}}/following?page=1&limit=20", "host": ["{{baseUrl}}"], "path": ["api","v1","users","{{userId}}","following"], "query": [{"key":"page","value":"1"},{"key":"limit","value":"20"}] },
            "description": "Get users that the given user follows."
          }
        }
      ]
    },
    {
      "name": "Posts",
      "description": "Global feed posts with cursor-based pagination",
      "item": [
        {
          "name": "Get Global Feed",
          "request": {
            "auth": { "type": "noauth" }, "method": "GET", "header": [],
            "url": { "raw": "{{baseUrl}}/api/v1/posts?limit=10", "host": ["{{baseUrl}}"], "path": ["api","v1","posts"], "query": [{"key":"limit","value":"10"},{"key":"cursor","value":"","disabled":true}] },
            "description": "Cursor-based global public feed. Pass cursor for subsequent pages. Auth optional."
          }
        },
        {
          "name": "Create Post",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) {", "  const json = pm.response.json();", "  pm.collectionVariables.set('postId', json.data.id);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"content\": \"Hello world! This is my first post.\",\n  \"visibility\": \"PUBLIC\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/v1/posts", "host": ["{{baseUrl}}"], "path": ["api","v1","posts"] },
            "description": "Create a post. Saves postId."
          }
        },
        {
          "name": "Create Post (with Image)",
          "event": [{ "listen": "test", "script": { "exec": ["if (pm.response.code === 201) {", "  const json = pm.response.json();", "  pm.collectionVariables.set('postId', json.data.id);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST", "header": [],
            "body": { "mode": "formdata", "formdata": [
              { "key": "content",    "value": "Check out this photo!", "type": "text" },
              { "key": "visibility", "value": "PUBLIC", "type": "text" },
              { "key": "image",      "type": "file", "src": "" }
            ]},
            "url": { "raw": "{{baseUrl}}/api/v1/posts", "host": ["{{baseUrl}}"], "path": ["api","v1","posts"] },
            "description": "Create a post with image upload (multipart/form-data, max 50 MB)."
          }
        },
        {
          "name": "Get Post By ID",
          "request": {
            "auth": { "type": "noauth" }, "method": "GET", "header": [],
